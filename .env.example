# Supabase project URL (from Supabase Dashboard > Settings > API)
VITE_SUPABASE_URL=

# Supabase anon public key (from Supabase Dashboard > Settings > API)
VITE_SUPABASE_ANON_KEY=

# Optional: passcode for local-dev fallback when Supabase is not configured.
# Ignored in production builds when Supabase keys are set.
VITE_ADMIN_PASSCODE=wanitaitu
